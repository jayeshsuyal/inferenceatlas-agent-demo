# LLM — set NEBIUS_API_KEY and/or OPENAI_API_KEY (Nebius takes precedence)
NEBIUS_API_KEY=
NEBIUS_BASE_URL=https://api.studio.nebius.com/v1/
NEBIUS_MODEL=meta-llama/Llama-3.3-70B-Instruct

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Force nebius or openai when both keys are set (optional)
# LLM_PROVIDER=openai

# Tavily live search (optional — skipped if unset)
TAVILY_API_KEY=

# Composio integrations (optional — dry-run by default for this public demo)
COMPOSIO_API_KEY=
COMPOSIO_DRY_RUN=1

AGENT_MAX_STEPS=10
