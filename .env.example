# LLM — set NEBIUS_API_KEY and/or OPENAI_API_KEY (Nebius takes precedence)
NEBIUS_API_KEY=
NEBIUS_BASE_URL=https://api.studio.nebius.com/v1/
NEBIUS_MODEL=meta-llama/Llama-3.3-70B-Instruct

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Force nebius or openai when both keys are set (optional)
# LLM_PROVIDER=openai

# Tavily live search (optional — skipped if unset)
TAVILY_API_KEY=

# Optional host OAuth *app* IDs (users sign in via popup; tokens stay in session files only)
# GitHub: https://github.com/settings/developers — callback {WEB_PUBLIC_URL}/api/connectors/oauth/callback/github
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
# Google Cloud Console — OAuth client, redirect {WEB_PUBLIC_URL}/api/connectors/oauth/callback/google_drive
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Must match the URL users open in the browser (for OAuth redirect)
WEB_PUBLIC_URL=http://127.0.0.1:8080

# Legacy server keys (optional fallback for chat LLM/search — NOT used for connector Sign in)
NEBIUS_API_KEY=
TAVILY_API_KEY=
COMPOSIO_API_KEY=
COMPOSIO_DRY_RUN=1

AGENT_MAX_STEPS=10

# InferenceAtlas-v1 product API (Option A — rank_configs / plan_llm for cost questions)
# Run v1 locally, then point here (e.g. uvicorn on :8000)
INFERENCEATLAS_V1_URL=
INFERENCEATLAS_V1_TIMEOUT=25

# ReviewRun Ask IA coach (deterministic skin + optional LLM/v1 bones)
COACH_SESSION_ENABLED=1
COACH_LLM_NARRATE=0
COACH_V1_GOVERNANCE=0
# IA_COACH_SESSION_DIR=state/coach_sessions
