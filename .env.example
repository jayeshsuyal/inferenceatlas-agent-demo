# Nebius OpenAI-compatible inference
NEBIUS_API_KEY=
NEBIUS_BASE_URL=https://api.studio.nebius.com/v1/
NEBIUS_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct-fast

# Tavily live search
TAVILY_API_KEY=

# Composio integrations remain dry-run by default for this public demo.
COMPOSIO_API_KEY=
COMPOSIO_DRY_RUN=1

AGENT_MAX_STEPS=6

