{
  "project": "InferenceAtlas Agent Demo",
  "repository_role": "Public redacted judge harness for the private InferenceAtlas v1 product",
  "one_line": "Pre-permission Trust Receipts, DecisionPackets, and access briefs for AI agents",
  "thesis": "Before an agent receives tools, data, spend, or production access, InferenceAtlas prepares a Trust Receipt, DecisionPacket, and Agent Access Decision Brief showing what can move, what stays blocked, whether the agent is eligible for this class of access, what proof is missing, who must review, and what validation comes next.",
  "agent_reviewer_instructions": "AGENTS.md",
  "reviewer_entrypoint": "docs/JUDGE_REVIEW_GUIDE.md",
  "default_run_command": "python3 -m agent.demo",
  "works_without_keys": true,
  "live_mode_command": "IA_LIVE_MODE=1 python3 -m agent.demo",
  "scenario_artifact_command": "python3 -m agent.scenarios",
  "scenario_review_command": "python3 -m agent.review --scenario read_only_analytics_agent",
  "scenario_review_json_command": "python3 -m agent.review --scenario admin_code_fix_bot --artifact packet --format json",
  "public_contract_command": "python3 -m agent.contract --all",
  "public_contract_artifact_command": "python3 -m agent.contract --all --generated-dir examples/generated",
  "policy_gate_command": "python3 -m agent.gate --all",
  "policy_gate_admin_command": "python3 -m agent.gate --scenario admin_code_fix_bot",
  "sponsor_adapter_command": "python3 -m agent.adapters --all",
  "sponsor_adapter_json_command": "python3 -m agent.adapters --all --json",
  "trust_receipt_command": "python3 -m agent.trust",
  "trust_receipt_json_command": "python3 -m agent.trust --print-json trust_receipt",
  "five_minute_review_commands": [
    "python3 -m agent.demo",
    "python3 -m agent.review --list",
    "python3 -m agent.contract --all",
    "python3 -m agent.gate --all",
    "python3 -m agent.adapters --all",
    "python3 -m agent.trust",
    "python3 -m unittest discover -s tests"
  ],
  "primary_demo_scenario": "Support triage agent requesting GitHub, Slack, and Jira access",
  "scenario_matrix": {
    "support_triage_agent": {
      "risk_shape": "medium_to_high",
      "packet": "examples/generated/support_triage_agent.packet.json",
      "decision_brief": "examples/generated/support_triage_agent.decision_brief.json",
      "expected_posture": "scoped_validation_allowed_production_blocked"
    },
    "read_only_analytics_agent": {
      "risk_shape": "low_read_only",
      "packet": "examples/generated/read_only_analytics_agent.packet.json",
      "decision_brief": "examples/generated/read_only_analytics_agent.decision_brief.json",
      "expected_posture": "read_only_validation_allowed"
    },
    "admin_code_fix_bot": {
      "risk_shape": "critical_admin_prod_write",
      "packet": "examples/generated/admin_code_fix_bot.packet.json",
      "decision_brief": "examples/generated/admin_code_fix_bot.decision_brief.json",
      "expected_posture": "validation_blocked_until_security_review"
    }
  },
  "primary_artifacts": {
    "markdown_packet": "examples/generated/support_triage_agent.packet.md",
    "json_packet": "examples/generated/support_triage_agent.packet.json",
    "markdown_decision_brief": "examples/generated/support_triage_agent.decision_brief.md",
    "json_decision_brief": "examples/generated/support_triage_agent.decision_brief.json",
    "markdown_trace": "examples/generated/support_triage_agent.trace.md",
    "json_trace": "examples/generated/support_triage_agent.trace.json",
    "demo_transcript": "examples/generated/demo_transcript.md",
    "trust_receipt_markdown": "examples/generated/trust_receipt.md",
    "trust_receipt_json": "examples/generated/trust_receipt.json",
    "review_room_markdown": "examples/generated/review_room.md",
    "review_room_json": "examples/generated/review_room.json",
    "policy_gate": "policy/agent_access.yml",
    "sponsor_adapters": "agent/adapters/",
    "agent_reviewer_instructions": "AGENTS.md",
    "judge_review_guide": "docs/JUDGE_REVIEW_GUIDE.md",
    "schema": "schemas/decision_packet.schema.json",
    "decision_brief_schema": "schemas/agent_access_decision_brief.schema.json",
    "public_contract": "docs/CONTRACT.md",
    "v1_capability_passport": "docs/V1_CAPABILITY_PASSPORT.md",
    "cto_handoff": "docs/CTO_HANDOFF.md",
    "architecture": "docs/ARCHITECTURE.md",
    "live_integration_contract": "docs/LIVE_INTEGRATION_CONTRACT.md"
  },
  "verification": {
    "ci_workflow": ".github/workflows/smoke.yml",
    "local_tests": "python3 -m unittest discover -s tests",
    "schema_parse": "python3 -m json.tool schemas/decision_packet.schema.json && python3 -m json.tool schemas/agent_access_decision_brief.schema.json",
    "artifact_parse": "python3 -m json.tool examples/generated/support_triage_agent.packet.json && python3 -m json.tool examples/generated/support_triage_agent.decision_brief.json",
    "cli_review": "python3 -m agent.review --list && python3 -m agent.review --scenario admin_code_fix_bot",
    "public_contract": "python3 -m agent.contract --all --generated-dir examples/generated",
    "policy_gate": "python3 -m agent.gate --all --json && python3 -m agent.gate --scenario admin_code_fix_bot",
    "sponsor_adapters": "python3 -m agent.adapters --all --json",
    "trust_receipt": "python3 -m agent.trust && python3 -m json.tool examples/generated/trust_receipt.json && python3 -m json.tool examples/generated/review_room.json"
  },
  "safety": {
    "approves_access": false,
    "grants_permissions": false,
    "external_writes_default": false,
    "composio_dry_run_default": true,
    "packet_state_mutation_default": false,
    "requires_human_approval": true,
    "default_public_demo_posture": "review_packet_only"
  },
  "sponsor_stack": {
    "nebius": "Optional live inference layer for reviewer-ready packet narration",
    "tavily": "Optional live evidence notes with source URLs and freshness status",
    "composio": "Optional scoped tool-access planning for GitHub, Slack, and Jira; dry-run by default",
    "openclaw": "Optional live-mode agent runtime harness"
  },
  "private_v1_boundary": {
    "private_source_exposed": false,
    "public_proof_surface": ["schemas", "examples", "trust receipt", "review room", "policy gate", "sponsor adapters", "decision brief", "CTO handoff", "tests", "CI", "redacted docs"],
    "principle": "private engine, public proof"
  },
  "builder_handoff_path": [
    "docs/CTO_HANDOFF.md",
    "docs/ARCHITECTURE.md",
    "docs/LIVE_INTEGRATION_CONTRACT.md",
    "agent/demo.py",
    "agent/packet.py",
    "agent/decision_brief.py",
    "tests/"
  ],
  "judge_review_path": [
    "AGENTS.md",
    "README.md",
    "docs/JUDGE_REVIEW_GUIDE.md",
    "BUILD_PLAN_TO_JUNE_12.md",
    "AI_JUDGE_MANIFEST.json",
    "examples/generated/trust_receipt.md",
    "examples/generated/review_room.md",
    "policy/agent_access.yml",
    "agent/adapters/",
    "examples/generated/demo_transcript.md",
    "examples/generated/support_triage_agent.decision_brief.md",
    "examples/generated/support_triage_agent.packet.md",
    "examples/generated/support_triage_agent.packet.json",
    "docs/V1_CAPABILITY_PASSPORT.md",
    "docs/SAFETY_CONTRACT.md",
    "python3 -m agent.demo"
  ]
}
