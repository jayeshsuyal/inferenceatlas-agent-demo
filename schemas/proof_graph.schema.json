{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jayeshsuyal/inferenceatlas-agent-demo/schemas/proof_graph.schema.json",
  "title": "InferenceAtlas ProofGraph",
  "description": "Public contract for packet-bound proof provenance. Live and fallback proof can attach to this graph, but graph nodes cannot approve, mutate, write, or change the IA Packet verdict.",
  "type": "object",
  "required": [
    "schema_version",
    "graph_id",
    "graph_revision_id",
    "content_hash",
    "generated_by",
    "mode",
    "scenario_name",
    "packet_reference",
    "packet_node",
    "proof_nodes",
    "proof_edges",
    "node_counts",
    "invariants",
    "safety_boundary",
    "private_boundary"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "proof_graph.v0"
    },
    "graph_id": {
      "type": "string",
      "pattern": "^ia-proof-graph-.+-[0-9a-f]{16}-public-v0$"
    },
    "graph_revision_id": {
      "type": "string",
      "pattern": "^pgr_[0-9a-f]{16}$"
    },
    "content_hash": {
      "$ref": "#/$defs/hash"
    },
    "generated_by": {
      "type": "string",
      "const": "inferenceatlas-agent-demo"
    },
    "mode": {
      "type": "string",
      "const": "offline_deterministic"
    },
    "scenario_name": {
      "type": "string",
      "minLength": 1
    },
    "packet_reference": {
      "$ref": "#/$defs/packet_reference"
    },
    "packet_node": {
      "$ref": "#/$defs/packet_node"
    },
    "proof_nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/proof_node"
      }
    },
    "proof_edges": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/proof_edge"
      }
    },
    "tavily_evidence": {
      "$ref": "#/$defs/tavily_evidence"
    },
    "composio_blast_radius": {
      "$ref": "#/$defs/composio_blast_radius"
    },
    "openclaw_runtime_trace": {
      "$ref": "#/$defs/openclaw_runtime_trace"
    },
    "nebius_reviewer_synthesis": {
      "$ref": "#/$defs/nebius_reviewer_synthesis"
    },
    "portkey_guardrail": {
      "$ref": "#/$defs/portkey_guardrail"
    },
    "node_counts": {
      "type": "object",
      "required": ["packet", "proof", "edge"],
      "properties": {
        "packet": { "type": "integer", "const": 1 },
        "proof": { "type": "integer", "minimum": 1 },
        "edge": { "type": "integer", "minimum": 1 }
      }
    },
    "invariants": {
      "$ref": "#/$defs/invariants"
    },
    "safety_boundary": {
      "$ref": "#/$defs/safety_boundary"
    },
    "private_boundary": {
      "$ref": "#/$defs/private_boundary"
    }
  },
  "$defs": {
    "hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "packet_reference": {
      "type": "object",
      "required": ["packet_id", "revision_id", "content_hash"],
      "properties": {
        "packet_id": { "type": "string", "minLength": 1 },
        "revision_id": { "type": "string", "pattern": "^rev_[0-9a-f]{16}$" },
        "content_hash": { "$ref": "#/$defs/hash" }
      }
    },
    "packet_node": {
      "type": "object",
      "required": [
        "node_id",
        "node_type",
        "packet_id",
        "revision_id",
        "content_hash",
        "decision_lock",
        "verdict",
        "review_posture",
        "next_human_action",
        "safety_state"
      ],
      "properties": {
        "node_id": { "type": "string", "pattern": "^packet:.+$" },
        "node_type": { "type": "string", "const": "packet" },
        "packet_id": { "type": "string", "minLength": 1 },
        "revision_id": { "type": "string", "pattern": "^rev_[0-9a-f]{16}$" },
        "content_hash": { "$ref": "#/$defs/hash" },
        "decision_lock": {
          "type": "string",
          "enum": ["approval_granted", "read_only_validation", "scoped_validation_only", "blocked"]
        },
        "verdict": { "type": "string", "minLength": 1 },
        "review_posture": { "type": "string", "minLength": 1 },
        "next_human_action": { "type": "string", "minLength": 1 },
        "safety_state": {
          "type": "object",
          "required": [
            "approval_granted",
            "external_writes_enabled",
            "packet_state_mutation",
            "requires_human_approval"
          ],
          "properties": {
            "approval_granted": { "type": "boolean", "const": false },
            "external_writes_enabled": { "type": "boolean", "const": false },
            "packet_state_mutation": { "type": "boolean", "const": false },
            "requires_human_approval": { "type": "boolean", "const": true }
          }
        }
      }
    },
    "proof_node": {
      "type": "object",
      "required": [
        "node_id",
        "node_type",
        "label",
        "provider",
        "mode",
        "api_call_made",
        "fallback_used",
        "external_write_made",
        "can_change_packet_verdict",
        "attached_packet_field",
        "human_review_required",
        "next_human_action",
        "summary",
        "source_refs"
      ],
      "properties": {
        "node_id": { "type": "string", "minLength": 1 },
        "node_type": { "type": "string", "const": "proof" },
        "label": { "type": "string", "minLength": 1 },
        "provider": {
          "type": "string",
          "enum": ["ia_packet", "tavily", "composio", "openclaw", "nebius", "portkey"]
        },
        "mode": {
          "type": "string",
          "enum": ["deterministic_packet_authority", "deterministic_fallback", "live_when_configured"]
        },
        "api_call_made": { "type": "boolean" },
        "fallback_used": { "type": "boolean" },
        "external_write_made": { "type": "boolean", "const": false },
        "can_change_packet_verdict": { "type": "boolean", "const": false },
        "attached_packet_field": {
          "type": "string",
          "enum": [
            "decision_lock",
            "blocked_claims",
            "missing_proof",
            "reviewer_routing",
            "next_human_action",
            "safety_invariants",
            "tool_scope",
            "source_candidates",
            "claim_ledger",
            "runtime_trace",
            "downstream_verdict"
          ]
        },
        "human_review_required": { "type": "boolean", "const": true },
        "next_human_action": { "type": "string", "minLength": 1 },
        "summary": { "type": "string" },
        "source_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "proof_edge": {
      "type": "object",
      "required": [
        "edge_id",
        "edge_type",
        "from_node_id",
        "to_node_id",
        "packet_field",
        "human_review_required",
        "can_change_packet_verdict"
      ],
      "properties": {
        "edge_id": { "type": "string", "minLength": 1 },
        "edge_type": {
          "type": "string",
          "enum": [
            "attaches_to_packet_field",
            "supports_review",
            "blocks_action",
            "requires_human_owner",
            "observed_by_downstream"
          ]
        },
        "from_node_id": { "type": "string", "minLength": 1 },
        "to_node_id": { "type": "string", "minLength": 1 },
        "packet_field": { "type": "string", "minLength": 1 },
        "human_review_required": { "type": "boolean", "const": true },
        "can_change_packet_verdict": { "type": "boolean", "const": false }
      }
    },
    "tavily_evidence": {
      "type": "object",
      "required": [
        "schema_version",
        "provider",
        "mode",
        "status",
        "live_requested",
        "live_call_attempted",
        "live_call_count",
        "used_live_key",
        "fallback_used",
        "fallback_reason",
        "query_count",
        "query_variant_count",
        "total_planned_searches",
        "source_url_count",
        "unique_source_url_count",
        "source_domain_count",
        "domain_diversity_score",
        "freshness_labels",
        "can_reduce_proof_debt",
        "cannot_grant_access",
        "human_review_required",
        "docs_reference",
        "safety_impact"
      ],
      "properties": {
        "schema_version": { "type": "string", "const": "tavily_live_evidence.v0" },
        "provider": { "type": "string", "const": "tavily" },
        "mode": { "type": "string", "const": "deterministic_fallback" },
        "status": { "type": "string", "const": "evidence_candidates_planned" },
        "live_requested": { "type": "boolean", "const": false },
        "live_call_attempted": { "type": "boolean", "const": false },
        "live_call_count": { "type": "integer", "const": 0 },
        "used_live_key": { "type": "boolean", "const": false },
        "fallback_used": { "type": "boolean", "const": true },
        "fallback_reason": { "type": "string", "const": "live_tavily_not_requested" },
        "query_count": { "type": "integer", "minimum": 0 },
        "query_variant_count": { "type": "integer", "minimum": 0 },
        "total_planned_searches": { "type": "integer", "minimum": 0 },
        "source_url_count": { "type": "integer", "minimum": 0 },
        "unique_source_url_count": { "type": "integer", "minimum": 0 },
        "source_domain_count": { "type": "integer", "minimum": 0 },
        "domain_diversity_score": { "type": "number", "minimum": 0, "maximum": 1 },
        "freshness_labels": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "can_reduce_proof_debt": { "type": "boolean", "const": false },
        "cannot_grant_access": { "type": "boolean", "const": true },
        "human_review_required": { "type": "boolean", "const": true },
        "docs_reference": { "type": "string", "minLength": 1 },
        "safety_impact": { "type": "string", "const": "none" }
      }
    },
    "composio_blast_radius": {
      "type": "object",
      "required": [
        "schema_version",
        "provider",
        "mode",
        "dry_run_enforced",
        "api_call_made",
        "composio_execute_allowed",
        "fallback_used",
        "tool_count",
        "blocked_action_count",
        "write_like_action_count",
        "admin_like_action_count",
        "high_or_critical_action_count",
        "required_proof_count",
        "max_risk_level",
        "all_blocked_before_execution",
        "all_write_or_admin_blocked",
        "would_execute",
        "candidate_action_slugs",
        "docs_reference",
        "sdk_docs_reference",
        "safety_impact"
      ],
      "properties": {
        "schema_version": { "type": "string", "const": "composio_dry_run_diff.v0" },
        "provider": { "type": "string", "const": "composio" },
        "mode": { "type": "string", "const": "deterministic_fallback" },
        "dry_run_enforced": { "type": "boolean", "const": true },
        "api_call_made": { "type": "boolean", "const": false },
        "composio_execute_allowed": { "type": "boolean", "const": false },
        "fallback_used": { "type": "boolean", "const": true },
        "tool_count": { "type": "integer", "minimum": 0 },
        "blocked_action_count": { "type": "integer", "minimum": 0 },
        "write_like_action_count": { "type": "integer", "minimum": 0 },
        "admin_like_action_count": { "type": "integer", "minimum": 0 },
        "high_or_critical_action_count": { "type": "integer", "minimum": 0 },
        "required_proof_count": { "type": "integer", "minimum": 0 },
        "max_risk_level": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "all_blocked_before_execution": { "type": "boolean", "const": true },
        "all_write_or_admin_blocked": { "type": "boolean", "const": true },
        "would_execute": { "type": "boolean", "const": false },
        "candidate_action_slugs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "docs_reference": { "type": "string", "minLength": 1 },
        "sdk_docs_reference": { "type": "string", "minLength": 1 },
        "safety_impact": { "type": "string", "const": "none" }
      }
    },
    "openclaw_runtime_trace": {
      "type": "object",
      "required": [
        "schema_version",
        "provider",
        "mode",
        "status",
        "api_call_made",
        "fallback_used",
        "checkpoint_count",
        "attempted_action_count",
        "blocked_event_count",
        "write_like_blocked_count",
        "admin_like_blocked_count",
        "high_or_critical_action_count",
        "all_attempted_actions_blocked",
        "runtime_write_attempted",
        "human_review_boundary_preserved",
        "would_execute",
        "safety_impact"
      ],
      "properties": {
        "schema_version": { "type": "string", "const": "sponsor_adapter_contract.v0" },
        "provider": { "type": "string", "const": "openclaw" },
        "mode": { "type": "string", "const": "deterministic_fallback" },
        "status": { "type": "string", "const": "trace_contract_planned" },
        "api_call_made": { "type": "boolean", "const": false },
        "fallback_used": { "type": "boolean", "const": true },
        "checkpoint_count": { "type": "integer", "minimum": 0 },
        "attempted_action_count": { "type": "integer", "minimum": 0 },
        "blocked_event_count": { "type": "integer", "minimum": 0 },
        "write_like_blocked_count": { "type": "integer", "minimum": 0 },
        "admin_like_blocked_count": { "type": "integer", "minimum": 0 },
        "high_or_critical_action_count": { "type": "integer", "minimum": 0 },
        "all_attempted_actions_blocked": { "type": "boolean", "const": true },
        "runtime_write_attempted": { "type": "boolean", "const": false },
        "human_review_boundary_preserved": { "type": "boolean", "const": true },
        "would_execute": { "type": "boolean", "const": false },
        "safety_impact": { "type": "string", "const": "none" }
      }
    },
    "nebius_reviewer_synthesis": {
      "type": "object",
      "required": [
        "schema_version",
        "provider",
        "mode",
        "status",
        "api_call_made",
        "fallback_used",
        "input_field_count",
        "draft_output_count",
        "locked_field_count",
        "llm_may_edit_count",
        "llm_must_not_edit_count",
        "required_anchor_count",
        "required_anchors_present",
        "forbidden_phrases_present",
        "can_change_verdict",
        "can_mutate_packet",
        "human_review_required",
        "safety_impact"
      ],
      "properties": {
        "schema_version": { "type": "string", "const": "sponsor_adapter_contract.v0" },
        "provider": { "type": "string", "const": "nebius" },
        "mode": { "type": "string", "const": "deterministic_fallback" },
        "status": { "type": "string", "const": "deterministic_narration_fallback" },
        "api_call_made": { "type": "boolean", "const": false },
        "fallback_used": { "type": "boolean", "const": true },
        "input_field_count": { "type": "integer", "minimum": 1 },
        "draft_output_count": { "type": "integer", "minimum": 1 },
        "locked_field_count": { "type": "integer", "minimum": 1 },
        "llm_may_edit_count": { "type": "integer", "minimum": 0 },
        "llm_must_not_edit_count": { "type": "integer", "minimum": 1 },
        "required_anchor_count": { "type": "integer", "minimum": 1 },
        "required_anchors_present": { "type": "boolean", "const": true },
        "forbidden_phrases_present": {
          "type": "array",
          "maxItems": 0,
          "items": { "type": "string" }
        },
        "can_change_verdict": { "type": "boolean", "const": false },
        "can_mutate_packet": { "type": "boolean", "const": false },
        "human_review_required": { "type": "boolean", "const": true },
        "safety_impact": { "type": "string", "const": "none" }
      }
    },
    "portkey_guardrail": {
      "type": "object",
      "required": [
        "schema_version",
        "provider",
        "mode",
        "delivery_mode",
        "webhook_path",
        "auth_required",
        "webhook_records_event",
        "preview_written_to_ledger",
        "response_verdict",
        "reason",
        "deny_reason_count",
        "policy_preview_mode",
        "api_call_made",
        "portkey_api_call_made",
        "portkey_policy_mutation_allowed",
        "packet_remains_authority",
        "raw_agent_intent_trusted",
        "live_portkey_mutation_enabled",
        "preview_does_not_write_ledger",
        "human_review_required",
        "docs_reference",
        "safety_impact"
      ],
      "properties": {
        "schema_version": { "type": "string", "const": "portkey_guardrail_proof_loop.v0" },
        "provider": { "type": "string", "const": "portkey" },
        "mode": { "type": "string", "const": "deterministic_fallback" },
        "delivery_mode": { "type": "string", "const": "live_guardrail_webhook" },
        "webhook_path": { "type": "string", "const": "/api/portkey/guardrail" },
        "auth_required": { "type": "boolean", "const": true },
        "webhook_records_event": { "type": "boolean", "const": true },
        "preview_written_to_ledger": { "type": "boolean", "const": false },
        "response_verdict": { "type": "boolean" },
        "reason": { "type": ["string", "null"] },
        "deny_reason_count": { "type": "integer", "minimum": 0 },
        "policy_preview_mode": { "type": "string", "const": "dry-run" },
        "api_call_made": { "type": "boolean", "const": false },
        "portkey_api_call_made": { "type": "boolean", "const": false },
        "portkey_policy_mutation_allowed": { "type": "boolean", "const": false },
        "packet_remains_authority": { "type": "boolean", "const": true },
        "raw_agent_intent_trusted": { "type": "boolean", "const": false },
        "live_portkey_mutation_enabled": { "type": "boolean", "const": false },
        "preview_does_not_write_ledger": { "type": "boolean", "const": true },
        "human_review_required": { "type": "boolean", "const": true },
        "docs_reference": {
          "type": "object",
          "required": ["guardrail_webhook", "guardrails_overview", "last_verified"],
          "properties": {
            "guardrail_webhook": { "type": "string", "minLength": 1 },
            "guardrails_overview": { "type": "string", "minLength": 1 },
            "last_verified": { "type": "string", "const": "2026-06-09" }
          }
        },
        "safety_impact": { "type": "string", "const": "none" }
      }
    },
    "invariants": {
      "type": "object",
      "required": [
        "packet_remains_authority",
        "graph_can_approve",
        "graph_can_mutate_packet",
        "graph_can_execute_external_write",
        "graph_can_change_verdict",
        "all_nodes_require_human_review",
        "all_nodes_non_mutating",
        "all_edges_non_mutating"
      ],
      "properties": {
        "packet_remains_authority": { "type": "boolean", "const": true },
        "graph_can_approve": { "type": "boolean", "const": false },
        "graph_can_mutate_packet": { "type": "boolean", "const": false },
        "graph_can_execute_external_write": { "type": "boolean", "const": false },
        "graph_can_change_verdict": { "type": "boolean", "const": false },
        "all_nodes_require_human_review": { "type": "boolean", "const": true },
        "all_nodes_non_mutating": { "type": "boolean", "const": true },
        "all_edges_non_mutating": { "type": "boolean", "const": true }
      }
    },
    "safety_boundary": {
      "type": "object",
      "required": [
        "approves_access",
        "grants_permissions",
        "executes_external_writes",
        "mutates_packet",
        "mutates_production",
        "changes_verdict",
        "requires_human_review"
      ],
      "properties": {
        "approves_access": { "type": "boolean", "const": false },
        "grants_permissions": { "type": "boolean", "const": false },
        "executes_external_writes": { "type": "boolean", "const": false },
        "mutates_packet": { "type": "boolean", "const": false },
        "mutates_production": { "type": "boolean", "const": false },
        "changes_verdict": { "type": "boolean", "const": false },
        "requires_human_review": { "type": "boolean", "const": true }
      }
    },
    "private_boundary": {
      "type": "object",
      "required": ["private_source_exposed", "principle"],
      "properties": {
        "private_source_exposed": { "type": "boolean", "const": false },
        "principle": { "type": "string", "const": "Private engine, public proof." }
      }
    }
  }
}
