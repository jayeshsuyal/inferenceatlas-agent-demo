{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jayeshsuyal/inferenceatlas-agent-demo/schemas/sponsor_value_receipts.schema.json",
  "title": "InferenceAtlas Sponsor Value Receipts",
  "description": "Public receipts showing what sponsor and downstream tools contributed to a ProofGraph without granting approval, executing writes, mutating packets, or changing verdicts.",
  "type": "object",
  "required": [
    "schema_version",
    "receipt_set_id",
    "generated_by",
    "scenario",
    "headline",
    "graph_reference",
    "packet_reference",
    "summary",
    "safety",
    "receipts",
    "private_boundary"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "sponsor_value_receipts.v0"
    },
    "receipt_set_id": {
      "type": "string",
      "pattern": "^ia-sponsor-value-receipts-.+-[0-9a-f]{16}-public-v0$"
    },
    "generated_by": {
      "type": "string",
      "const": "inferenceatlas-agent-demo"
    },
    "scenario": {
      "type": "string",
      "minLength": 1
    },
    "headline": {
      "type": "string",
      "const": "Sponsors provide proof signals. IA converts them into packet authority."
    },
    "graph_reference": {
      "type": "object",
      "required": ["graph_id", "graph_revision_id", "content_hash"],
      "properties": {
        "graph_id": { "type": "string", "minLength": 1 },
        "graph_revision_id": { "type": "string", "pattern": "^pgr_[0-9a-f]{16}$" },
        "content_hash": { "$ref": "#/$defs/hash" }
      }
    },
    "packet_reference": {
      "type": "object",
      "required": ["packet_id", "revision_id", "content_hash"],
      "properties": {
        "packet_id": { "type": "string", "minLength": 1 },
        "revision_id": { "type": "string", "pattern": "^rev_[0-9a-f]{16}$" },
        "content_hash": { "$ref": "#/$defs/hash" }
      }
    },
    "summary": {
      "type": "object",
      "required": ["provider_count", "receipt_count", "providers", "proof_node_count", "proof_edge_count"],
      "properties": {
        "provider_count": { "type": "integer", "const": 5 },
        "receipt_count": { "type": "integer", "const": 5 },
        "providers": {
          "type": "array",
          "prefixItems": [
            { "type": "string", "const": "tavily" },
            { "type": "string", "const": "composio" },
            { "type": "string", "const": "openclaw" },
            { "type": "string", "const": "nebius" },
            { "type": "string", "const": "portkey" }
          ],
          "minItems": 5,
          "maxItems": 5
        },
        "proof_node_count": { "type": "integer", "minimum": 1 },
        "proof_edge_count": { "type": "integer", "minimum": 1 }
      }
    },
    "safety": {
      "$ref": "#/$defs/safety"
    },
    "receipts": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": {
        "$ref": "#/$defs/receipt"
      }
    },
    "private_boundary": {
      "$ref": "#/$defs/private_boundary"
    }
  },
  "$defs": {
    "hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "safety": {
      "type": "object",
      "required": [
        "packet_remains_authority",
        "all_receipts_require_human_review",
        "all_receipts_non_approving",
        "all_receipts_non_granting",
        "all_receipts_non_executing",
        "all_receipts_non_mutating",
        "all_receipts_preserve_verdict",
        "all_receipts_non_auto_reducing"
      ],
      "properties": {
        "packet_remains_authority": { "type": "boolean", "const": true },
        "all_receipts_require_human_review": { "type": "boolean", "const": true },
        "all_receipts_non_approving": { "type": "boolean", "const": true },
        "all_receipts_non_granting": { "type": "boolean", "const": true },
        "all_receipts_non_executing": { "type": "boolean", "const": true },
        "all_receipts_non_mutating": { "type": "boolean", "const": true },
        "all_receipts_preserve_verdict": { "type": "boolean", "const": true },
        "all_receipts_non_auto_reducing": { "type": "boolean", "const": true }
      }
    },
    "receipt": {
      "type": "object",
      "required": [
        "schema_version",
        "receipt_id",
        "provider",
        "role",
        "contribution_type",
        "sponsor_value",
        "downstream_value",
        "what_stayed_blocked",
        "proof_node_count",
        "attached_packet_fields",
        "source_refs",
        "key_metrics",
        "ia_authority_boundary",
        "safety_boundary"
      ],
      "properties": {
        "schema_version": { "type": "string", "const": "sponsor_value_receipt.v0" },
        "receipt_id": { "type": "string", "pattern": "^svr_[a-z]+_[0-9a-f]{12}$" },
        "provider": {
          "type": "string",
          "enum": ["tavily", "composio", "openclaw", "nebius", "portkey"]
        },
        "role": { "type": "string", "minLength": 1 },
        "contribution_type": { "type": "string", "minLength": 1 },
        "sponsor_value": { "type": "string", "minLength": 1 },
        "downstream_value": { "type": "string", "minLength": 1 },
        "what_stayed_blocked": { "type": "string", "minLength": 1 },
        "proof_node_count": { "type": "integer", "minimum": 1 },
        "attached_packet_fields": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "source_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "key_metrics": { "type": "object" },
        "ia_authority_boundary": { "type": "string", "minLength": 1 },
        "safety_boundary": {
          "type": "object",
          "required": [
            "can_approve",
            "can_grant_permissions",
            "can_execute_external_write",
            "can_mutate_packet",
            "can_change_verdict",
            "can_reduce_proof_debt_automatically",
            "requires_human_review"
          ],
          "properties": {
            "can_approve": { "type": "boolean", "const": false },
            "can_grant_permissions": { "type": "boolean", "const": false },
            "can_execute_external_write": { "type": "boolean", "const": false },
            "can_mutate_packet": { "type": "boolean", "const": false },
            "can_change_verdict": { "type": "boolean", "const": false },
            "can_reduce_proof_debt_automatically": { "type": "boolean", "const": false },
            "requires_human_review": { "type": "boolean", "const": true }
          }
        }
      }
    },
    "private_boundary": {
      "type": "object",
      "required": ["private_source_exposed", "principle"],
      "properties": {
        "private_source_exposed": { "type": "boolean", "const": false },
        "principle": { "type": "string", "const": "Private engine, public proof." }
      }
    }
  }
}
